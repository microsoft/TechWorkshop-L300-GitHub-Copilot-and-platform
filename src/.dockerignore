bin/
obj/
out/

# Exclude IDE files
.vscode/
.vs/
*.user
*.suo

# Exclude OS files
Thumbs.db
.DS_Store

# Exclude temp files
*.tmp
*.temp

# Exclude logs
*.log
logs/

# Exclude packages
packages/