# .dockerignore for ZavaStorefront
# Exclude build artifacts and unnecessary files from Docker build context

# Binaries
bin/
obj/

# IDE and editor files
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]rtifacts/

# Development settings
appsettings.Development.json

# Git
.git/
.gitignore
.gitattributes

# Documentation
*.md
README.md

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet
*.nupkg
*.snupkg
packages/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
