@model ZavaStorefront.Models.ChatViewModel

@{
    ViewData["Title"] = "Chat";
}

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <h1 class="mb-3">Chat</h1>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-warning" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <form asp-controller="Chat" asp-action="Send" method="post">
            <div class="mb-3">
                <label asp-for="ConversationHistory" class="form-label">Conversation</label>
                <textarea asp-for="ConversationHistory" class="form-control" rows="12" readonly></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Prompt" class="form-label">Message</label>
                <input asp-for="Prompt" class="form-control" placeholder="Type a message to Phi-4" />
                <span asp-validation-for="Prompt" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Send</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}