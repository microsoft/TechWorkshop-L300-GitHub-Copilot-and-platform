{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "11679760506899471769"
    }
  },
  "parameters": {
    "aiHubName": {
      "type": "string",
      "metadata": {
        "description": "Name of the AI Hub (Microsoft Foundry)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the AI Hub"
      }
    },
    "displayName": {
      "type": "string",
      "defaultValue": "ZavaStorefront AI Hub",
      "metadata": {
        "description": "Display name for the AI Hub"
      }
    },
    "hubDescription": {
      "type": "string",
      "defaultValue": "AI Hub for ZavaStorefront application with GPT-4 and Phi models",
      "metadata": {
        "description": "Description for the AI Hub"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags to apply to the resource"
      }
    },
    "storageAccountId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Storage account ID for the AI Hub"
      }
    },
    "keyVaultId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Key Vault ID for the AI Hub"
      }
    },
    "appInsightsId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Application Insights ID for the AI Hub"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.MachineLearningServices/workspaces",
      "apiVersion": "2024-04-01",
      "name": "[parameters('aiHubName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "Hub",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "friendlyName": "[parameters('displayName')]",
        "description": "[parameters('hubDescription')]",
        "storageAccount": "[if(not(empty(parameters('storageAccountId'))), parameters('storageAccountId'), null())]",
        "keyVault": "[if(not(empty(parameters('keyVaultId'))), parameters('keyVaultId'), null())]",
        "applicationInsights": "[if(not(empty(parameters('appInsightsId'))), parameters('appInsightsId'), null())]",
        "publicNetworkAccess": "Enabled"
      },
      "sku": {
        "name": "Basic",
        "tier": "Basic"
      }
    }
  ],
  "outputs": {
    "aiHubId": {
      "type": "string",
      "metadata": {
        "description": "The resource ID of the AI Hub"
      },
      "value": "[resourceId('Microsoft.MachineLearningServices/workspaces', parameters('aiHubName'))]"
    },
    "aiHubName": {
      "type": "string",
      "metadata": {
        "description": "The name of the AI Hub"
      },
      "value": "[parameters('aiHubName')]"
    },
    "principalId": {
      "type": "string",
      "metadata": {
        "description": "The principal ID of the system-assigned managed identity"
      },
      "value": "[reference(resourceId('Microsoft.MachineLearningServices/workspaces', parameters('aiHubName')), '2024-04-01', 'full').identity.principalId]"
    }
  }
}